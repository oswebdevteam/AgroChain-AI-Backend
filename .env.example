# --- Server ---
NODE_ENV=development
PORT=3000
API_VERSION=v1

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Frontend URL for payment callbacks (should match your deployed frontend)
FRONTEND_URL=http://localhost:3000

# --- Supabase ---
# Get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT secret for verifying Supabase JWTs (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Interswitch Payment Gateway ---
# Register at https://sandbox.interswitchng.com for test credentials
INTERSWITCH_BASE_URL=https://sandbox.interswitchng.com
INTERSWITCH_CLIENT_ID=your-interswitch-client-id
INTERSWITCH_CLIENT_SECRET=your-interswitch-client-secret
INTERSWITCH_MERCHANT_CODE=your-merchant-code
INTERSWITCH_PAYMENT_ITEM_ID=your-payment-item-id
# Webhook signature verification secret
INTERSWITCH_WEBHOOK_SECRET=your-webhook-secret

# --- Blockchain (Base Sepolia Testnet) ---
# Base Sepolia testnet RPC endpoint
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Private key of the wallet used for recording trade events (NEVER use mainnet key)
BLOCKCHAIN_PRIVATE_KEY=0xyour-testnet-private-key
# Address of the deployed TradeLogger contract on Base Sepolia
TRADE_LOGGER_CONTRACT_ADDRESS=0xyour-contract-address
# Base Sepolia chain ID (always 84532)
BASE_SEPOLIA_CHAIN_ID=84532

# --- OpenAI (AI Financial Identity Engine) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
# Max tokens for credit analysis response
OPENAI_MAX_TOKENS=1500

# --- FX Rate API (Cross-Border Intelligence) ---
# Free tier from exchangerate-api.com or similar
FX_API_BASE_URL=https://v6.exchangerate-api.com/v6
FX_API_KEY=your-fx-api-key

# --- Rate Limiting ---
# Requests per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Stricter limits for auth endpoints
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# --- Logging ---
LOG_LEVEL=info
